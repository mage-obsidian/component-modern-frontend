VITE_SERVER_HOST=phpfpm
VITE_SERVER_PORT=5173
VITE_SERVER_SECURE=true
VITE_HMR_PATH=/__vite_ping
MAGENTO_HOST=magento.test
VITE_SERVER_ALLOWED_HOSTS=magento.test,localhost

# Optional. Rewrites the absolute paths in the generated theme jsconfig.json
# (the `Vendor_Module::` import targets and the node_modules wildcard) so
# go-to-definition and npm autocomplete land where your editor opens the files.
# Only needed when the build runs on a different filesystem/mount than your editor
# (e.g. a container). Format: `from=>to`, comma-separated for multiple mounts; the
# longest matching `from` wins, so order does not matter. Add one entry per mount:
# the Magento root, plus any nested mount such as the vite harness (whose
# node_modules the wildcard points at) if it maps to a different host path.
# Example (Magento root at /var/www/html, harness overlaid at /var/www/html/vite):
# MAGE_OBSIDIAN_TYPES_PATH_MAP=/var/www/html/vite=>/abs/host/component-modern-frontend/vite,/var/www/html=>/abs/host/path/to/magento-root
